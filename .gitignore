# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (anywhere in the tree, e.g. frontend/node_modules)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js build output
.next/
out/

# python / backend
**/__pycache__/
**/.venv/
**/*.pyc
**/.pytest_cache/

# env files
.env
.env.*
!.env.example
env

# misc
.DS_Store
*.pem
coverage/
dist/
build/

# debug
npm-debug.log*
npm-start-*.log
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# typescript
*.tsbuildinfo
next-env.d.ts

# vercel
.vercel

# editor / agent state
.claude/
.vscode/
.idea/
