# ================================================================
# RoomieFit / CampusNest Israel — environment variables
#
# Local development: copy this file to .env and fill in values.
# Railway deployment: paste these keys into the service Variables tab.
# ================================================================

# --- Node runtime ------------------------------------------------
NODE_ENV=production
# PORT is auto-injected by Railway. For local dev, override to 4000
# (or whatever you prefer). Server reads process.env.PORT.
PORT=4000

# --- Supabase (required) -----------------------------------------
# Find these at:
#   https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI Agents SDK (required for the AI assistant) -----------
# Create at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional model override — defaults to gpt-4o if unset.
OPENAI_AGENT_MODEL=gpt-4o

# --- Telegram bot (optional) -------------------------------------
# From @BotFather. If unset, the bot mode falls back to mock.
TELEGRAM_BOT_TOKEN=

# --- Public URL (optional, for CORS) -----------------------------
# The public URL Railway assigns. Used only for CORS origin
# restriction; safe to leave blank in dev (defaults to allow-all).
PUBLIC_APP_URL=
